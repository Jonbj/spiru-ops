# ---- Discovery APIs ----
BRAVE_API_KEY=__PUT_YOUR_BRAVE_KEY_HERE__
# Max Brave queries per discover run (0 = no limit). Safety cap for API costs.
# At ~$3/1000 queries, 1 run/day: 50→$4.5/mo | 80→$7.2/mo | 0 (no cap)→~$11/mo
BRAVE_MAX_QUERIES_PER_RUN=0
OPENAI_API_KEY=__PUT_YOUR_OPENAI_KEY_HERE__

# Model for chat/copilot (Responses API)
OPENAI_MODEL=gpt-4o
# Alternative deep research model (optional)
OPENAI_DEEP_RESEARCH_MODEL=o3-deep-research

# ---- Multi-backend LLM (copilot) ----
# Set LLM_BACKEND to: openai (default) | anthropic | ollama
LLM_BACKEND=openai
ANTHROPIC_API_KEY=__PUT_YOUR_ANTHROPIC_KEY_HERE__
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ---- Services ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=docs_chunks_v2

UNSTRUCTURED_URL=http://localhost:8000
GROBID_URL=http://localhost:8070
GROBID_ENABLE=0
GROBID_FULLTEXT=0

# ---- Storage ----
RAW_DIR=storage/raw
PARSED_DIR=storage/parsed
ARTIFACTS_DIR=storage/artifacts
STATE_DIR=storage/state

# ---- Discovery knobs ----
MAX_CANDIDATES_PER_FOCUS=90
MAX_TOTAL_CANDIDATES=1200
DISCOVERY_SINCE_DAYS=120
DISCOVER_MAX_CAND_PER_DOMAIN=6
DENY_RESEARCHGATE=1
RESOLVE_DOI_REDIRECTS=1
RESOLVE_DOI_TIMEOUT_S=8

# Courtesy email for OpenAlex polite pool (recommended, reduces rate limiting)
OPENALEX_EMAIL=you@example.com
UNPAYWALL_EMAIL=you@example.com
CROSSREF_MAILTO=you@example.com

# CORE API key (optional, increases paper coverage)
CORE_API_KEY=__PUT_YOUR_CORE_KEY_HERE__
# Seconds between CORE requests — free tier allows ~10-20 req/min (6.5s ≈ safe)
CORE_SLEEP_S=6.5
# Disable CORE for the rest of the run after this many unrecovered 429s
CORE_MAX_429=3

USER_AGENT=spiru-ops-bot/0.3 (+local research; contact: you@example.com)

# ---- Pipeline knobs ----
SEED_STRAINS=0
INGEST_TARGET=300
INGEST_MAX_PER_DOMAIN=10
INGEST_MAX_PER_FOCUS_PCT=10%
INGEST_EXPLORATION_PCT=70%
INGEST_HISTORY_DAYS=14
MAX_DOWNLOAD_MB=250

# ---- OCR ----
OCR_LIMIT=5

# ---- Indexing ----
EMBED_MODEL=BAAI/bge-m3
CHUNK_MAX_CHARS=2200
CHUNK_OVERLAP=240

# ---- Reporting ----
TOP_K_PER_FOCUS=12

# ---- QC thresholds ----
QC_MIN_INDEXED_POINTS=200
QC_MIN_SPIRULINA_SHARE=0.35
QC_SPIRULINA_SCORE_THRESHOLD=0.35
QC_MIN_AVG_SPIRULINA_SCORE=0.28
QC_MIN_PREFER_SHARE=0.05

# Optional webhook for failure notifications
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/...

# ---- Copilot ----
COPILOT_TOPK=10
COPILOT_MAX_CONTEXT_CHARS=18000
