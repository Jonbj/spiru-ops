# ---- Discovery APIs ----

# SearXNG (self-hosted, free) — primary web search. Leave empty to use Brave instead.
# Start with: docker compose up -d searxng
# See configs/searxng/settings.yml for engine configuration.
SEARXNG_URL=http://localhost:8888

# Brave Search API (fallback when SEARXNG_URL is empty)
BRAVE_API_KEY=__PUT_YOUR_BRAVE_KEY_HERE__
# Max Brave queries per discover run (0 = no limit). Only applies when using Brave, not SearXNG.
# At ~$3/1000 queries, 1 run/day: 50→$4.5/mo | 80→$7.2/mo | 0 (no cap)→~$11/mo
BRAVE_MAX_QUERIES_PER_RUN=0

# Semantic Scholar (free academic API, 200M+ papers — complements OpenAlex/CORE)
# Optional API key increases rate limit. Register at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_KEY=
OPENAI_API_KEY=__PUT_YOUR_OPENAI_KEY_HERE__

# Model for chat/copilot (Responses API)
OPENAI_MODEL=gpt-4o
# Alternative deep research model (optional)
OPENAI_DEEP_RESEARCH_MODEL=o3-deep-research

# ---- Multi-backend LLM (copilot) ----
# Set LLM_BACKEND to: openai (default) | anthropic | ollama
LLM_BACKEND=openai
ANTHROPIC_API_KEY=__PUT_YOUR_ANTHROPIC_KEY_HERE__
ANTHROPIC_MODEL=claude-sonnet-4-6
# Local llama-server (llama.cpp) — API-compatible con OpenAI su porta 8080
# Avvio: ~/.models/start-server.sh   Arresto: ~/.models/stop-server.sh
# Modello attivo: DeepSeek-R1-Distill-Qwen-14B Q4_K_M (~10 tok/s, ctx 8192 token)
# Per usarlo: LLM_BACKEND=ollama + impostare COPILOT_MAX_CONTEXT_CHARS=12000
OLLAMA_URL=http://127.0.0.1:8080
OLLAMA_MODEL=local

# ---- Services ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=docs_chunks_v2

UNSTRUCTURED_URL=http://localhost:8000
GROBID_URL=http://localhost:8070
GROBID_ENABLE=0
GROBID_FULLTEXT=0

# ---- Storage ----
RAW_DIR=storage/raw
PARSED_DIR=storage/parsed
ARTIFACTS_DIR=storage/artifacts
STATE_DIR=storage/state

# ---- Discovery knobs ----
MAX_CANDIDATES_PER_FOCUS=90
MAX_TOTAL_CANDIDATES=1200
DISCOVERY_SINCE_DAYS=120
DISCOVER_MAX_CAND_PER_DOMAIN=6
DENY_RESEARCHGATE=1
RESOLVE_DOI_REDIRECTS=1
RESOLVE_DOI_TIMEOUT_S=8

# Courtesy email for OpenAlex polite pool (recommended, reduces rate limiting)
OPENALEX_EMAIL=you@example.com
UNPAYWALL_EMAIL=you@example.com
CROSSREF_MAILTO=you@example.com

# CORE API key (optional, increases paper coverage)
CORE_API_KEY=__PUT_YOUR_CORE_KEY_HERE__
# Seconds between CORE requests — free tier allows ~10-20 req/min (6.5s ≈ safe)
CORE_SLEEP_S=6.5
# Disable CORE for the rest of the run after this many unrecovered 429s
CORE_MAX_429=3

USER_AGENT=spiru-ops-bot/0.3 (+local research; contact: you@example.com)

# ---- Pipeline knobs ----
SEED_STRAINS=0
INGEST_TARGET=300
INGEST_MAX_PER_DOMAIN=10
INGEST_MAX_PER_FOCUS_PCT=10%
INGEST_EXPLORATION_PCT=70%
INGEST_HISTORY_DAYS=14
MAX_DOWNLOAD_MB=250

# ---- OCR ----
OCR_LIMIT=5

# ---- Indexing ----
EMBED_MODEL=BAAI/bge-m3
CHUNK_MAX_CHARS=2200
CHUNK_OVERLAP=240

# ---- Reporting ----
TOP_K_PER_FOCUS=12

# ---- QC thresholds ----
QC_MIN_INDEXED_POINTS=200
QC_MIN_SPIRULINA_SHARE=0.35
QC_SPIRULINA_SCORE_THRESHOLD=0.35
QC_MIN_AVG_SPIRULINA_SCORE=0.28
QC_MIN_PREFER_SHARE=0.05

# Optional webhook for failure notifications
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/...

# ---- LLM augmentation features (all opt-in, all use OLLAMA_URL/OLLAMA_MODEL) ----
# daily.sh auto-starts ~/.models/start-server.sh if any feature is enabled and
# the server is not already running.

# ingest.py: re-scores borderline docs (keyword score 0.05–0.50) with LLM.
# Blend: 35% keyword + 65% LLM. ~1-2 min extra per run on ~20-40 borderline docs.
RELEVANCE_LLM_ENABLE=0
RELEVANCE_LLM_MIN_KW=0.05
RELEVANCE_LLM_MAX_KW=0.50

# discover.py: generates 3 extra search queries per focus via LLM, cached for N days.
# Cache TTL avoids calling LLM on every run (only regenerates when cache expires).
# At 24 focuses × ~30s = ~12 min first run, then free until cache expires.
DISCOVER_LLM_EXPAND=0
DISCOVER_LLM_CACHE_DAYS=3

# report.py: appends a short Italian narrative commentary on run quality.
# Activated automatically when RELEVANCE_LLM_ENABLE=1, or set independently.
REPORT_LLM_ENABLE=0

# GPU safety: stop the LLM server before index.py (BGE-M3 embedding) to free VRAM.
# Set to 1 if the LLM server and BGE-M3 don't fit in GPU memory simultaneously.
# When =1 and the server was started by the pipeline (or was already running),
# daily.sh stops it before index and does NOT restart it after.
LLM_PIPELINE_GPU_SAFE=0

# Shared LLM server settings (all three features above use these)
RELEVANCE_LLM_TIMEOUT=60
# Override server/model (defaults to OLLAMA_URL / OLLAMA_MODEL)
# RELEVANCE_LLM_URL=http://127.0.0.1:8080
# RELEVANCE_LLM_MODEL=local

# ---- Copilot ----
COPILOT_TOPK=10
COPILOT_MAX_CONTEXT_CHARS=18000
