# ---- Discovery APIs ----
BRAVE_API_KEY=__PUT_YOUR_BRAVE_KEY_HERE__
OPENAI_API_KEY=__PUT_YOUR_OPENAI_KEY_HERE__

# Model for chat/copilot (Responses API)
OPENAI_MODEL=gpt-5.2
# Alternative deep research model (optional)
OPENAI_DEEP_RESEARCH_MODEL=o3-deep-research

# ---- Services ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=docs_chunks

UNSTRUCTURED_URL=http://localhost:8000
GROBID_URL=http://localhost:8070

# ---- Storage ----
RAW_DIR=storage/raw
PARSED_DIR=storage/parsed
ARTIFACTS_DIR=storage/artifacts
STATE_DIR=storage/state

# ---- Pipeline knobs ----
MAX_CANDIDATES_PER_FOCUS=20
MAX_TOTAL_CANDIDATES=120
DISCOVERY_SINCE_DAYS=14

USER_AGENT=spiru-ops-bot/0.3 (+local research; contact: you@example.com)

# ---- Indexing ----
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_MAX_CHARS=2200
CHUNK_OVERLAP=240

# ---- Reporting ----
TOP_K_PER_FOCUS=12

# ---- Copilot ----
COPILOT_TOPK=10
COPILOT_MAX_CONTEXT_CHARS=18000
